# ── Google Sheets ──────────────────────────────────────────────
# ID de la hoja (viene de la URL: /spreadsheets/d/<SHEET_ID>/edit)
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Email de la Service Account (Google Cloud Console → IAM → Service Accounts)
GOOGLE_SERVICE_ACCOUNT_EMAIL=huevos@tu-proyecto.iam.gserviceaccount.com

# Clave privada de la Service Account (JSON → private_key)
# Mantén las \n literales — Next.js las convierte internamente
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
